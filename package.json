{
  "name": "mongoose-currency-convert",
  "version": "0.1.5",
  "description": "A lightweight Mongoose plugin for automatic currency conversion at save and update time — flexible, extensible, and service-agnostic.",
  "keywords": [
    "mongoose",
    "plugin",
    "currency",
    "conversion",
    "exchange-rate",
    "mongodb",
    "typescript",
    "money"
  ],
  "license": "MIT",
  "author": {
    "name": "maku85",
    "email": "makuma85@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maku85/mongoose-currency-convert.git"
  },
  "homepage": "https://github.com/maku85/mongoose-currency-convert#readme",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./cache": {
      "types": "./dist/utils/cache.d.ts",
      "import": "./dist/utils/cache.mjs",
      "require": "./dist/utils/cache.js"
    },
    "./types": {
      "types": "./dist/types.d.ts"
    },
    "./validate": {
      "types": "./dist/validate.d.ts",
      "import": "./dist/validate.mjs",
      "require": "./dist/validate.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "prepare": "husky",
    "lint": "biome check src --verbose",
    "format": "biome format src --write",
    "prepublishOnly": "pnpm build",
    "release": "commit-and-tag-version",
    "release:minor": "commit-and-tag-version --release-as minor",
    "release:major": "commit-and-tag-version --release-as major",
    "release:dry": "commit-and-tag-version --dry-run",
    "test": "mocha --config .mocharc.json",
    "test:watch": "mocha --watch --config .mocharc.json",
    "coverage": "nyc pnpm test"
  },
  "peerDependencies": {
    "mongoose": ">=7.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.5",
    "@commitlint/config-conventional": "^20.0.0",
    "@types/chai": "^5.2.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.7.0",
    "chai": "^6.2.0",
    "commit-and-tag-version": "^12.6.1",
    "commitlint": "^20.1.0",
    "husky": "^9.1.7",
    "mocha": "^11.7.4",
    "mongoose": "^8.19.0",
    "nyc": "^17.1.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "commit-and-tag-version": {
    "types": [
      { "type": "feat", "section": "Features" },
      { "type": "fix", "section": "Bug Fixes" },
      { "type": "perf", "section": "Performance" },
      { "type": "revert", "section": "Reverts" },
      { "type": "docs", "hidden": true },
      { "type": "chore", "hidden": true },
      { "type": "refactor", "hidden": true },
      { "type": "test", "hidden": true }
    ],
    "scripts": {
      "prerelease": "pnpm test",
      "postbump": "echo 'Version bumped to' $(node -p \"require('./package.json').version\")"
    }
  },
  "nyc": {
    "extension": [
      ".ts"
    ],
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "test/**/*.ts",
      "dist/**/*.ts"
    ],
    "reporter": [
      "text",
      "lcov"
    ],
    "all": true,
    "check-coverage": true,
    "lines": 90,
    "functions": 90,
    "branches": 80,
    "statements": 90
  }
}
